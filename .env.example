# Server Configuration
PORT=8000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Sarvam AI Configuration
SARVAM_AI_API_KEY=your_sarvam_ai_api_key_here
# Backward-compatible alias (optional if SARVAM_AI_API_KEY is set)
SARVAM_API_KEY=
SARVAM_AI_BASE_URL=https://api.sarvam.ai/v1

# Twilio Configuration (for real phone calls)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
WEBHOOK_BASE_URL=https://your-domain.com

# Feature Flags
ENABLE_REAL_CALLS=false  # Set to true to use real Twilio calls instead of simulation
USE_SARVAM_AI=false      # Set to true to use Sarvam AI APIs for TTS/STT
MAX_REAL_CALLS_PER_DAY=2 # Safety limit to protect API/telephony credits

# Database Configuration (for production)
DATABASE_URL=postgresql://user:password@localhost:5432/sarvam_ai
REDIS_URL=redis://localhost:6379/0

# Cloud Storage (for audio files)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
S3_BUCKET_NAME=sarvam-ai-recordings

# Logging
LOG_LEVEL=INFO
